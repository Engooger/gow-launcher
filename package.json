{
  "name": "gow-launcher",
  "version": "0.1.0",
  "description": "God of War Minecraft modpack launcher",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder --win",
    "publish-pack": "node scripts/publish-modpack.mjs"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.8.3",
    "minecraft-launcher-core": "^3.18.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.gow.launcher",
    "productName": "GoW Launcher",
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "icon": "build-assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Engooger",
        "repo": "gow-launcher"
      }
    ]
  }
}
